    "schedules": [],
    "combinedCode": "## ═══════════════════════════════════════════════════════════════\n## STAGE1 - REVENUE ALLOCATION\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\n## Steps\ncatalog_ids = collect_all(CATALOG.ProductId)\nprint(\"catalog_ids =\", catalog_ids)\ncatalog_name = collect_all(CATALOG.ProductName)\nprint(\"catalog_name =\", catalog_name)\nproduct_id = collect_by_instrument(REV.ATTRIBUTE_PRODUCT_ID_CURRENT)\nprint(\"product_id =\", product_id)\nproduct_names = lookup(catalog_name,catalog_ids,product_id)\nprint(\"product_names =\", product_names)\nsale_price = collect_by_instrument(REV.ATTRIBUTE_SALE_PRICE_CURRENT)\nprint(\"sale_price =\", sale_price)\nquantity = collect_by_instrument(REV.ATTRIBUTE_QUANTITY_CURRENT)\nprint(\"quantity =\", quantity)\nesp_values = multiply(sale_price, quantity)\nprint(\"esp_values =\", esp_values)\n## Iteration\nSSP = apply_each(product_names, \"if(eq_ignore_case(each, 'discount'), 0, array_get(esp_values, index, 0))\", {\"product_names\": product_names, \"esp_values\": esp_values})\nprint(\"SSP =\", SSP)\n\nsubinstrument_ids = collect_by_instrument(REV.subinstrumentid)\nprint(\"subinstrument_ids =\", subinstrument_ids)\ntotalssp = sum(SSP)\nprint(\"totalssp =\", totalssp)\ntotalesp = sum(esp_values)\nprint(\"totalesp =\", totalesp)\n## Iteration\nratio = apply_each(SSP, \"divide(each,totalssp)\", {\"SSP\": SSP, \"totalssp\": totalssp})\nprint(\"ratio =\", ratio)\n\n## Iteration\nallocation = apply_each(ratio, \"multiply(each,totalesp)\", {\"totalesp\": totalesp, \"ratio\": ratio})\nprint(\"allocation =\", allocation)\n\n\n## ═══════════════════════════════════════════════════════════════\n## STAGE 2 - REVENUE SCHEDULE\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\n## Steps\nstart_dates = collect_by_instrument(REV.ATTRIBUTE_ITEM_STARTDATE_CURRENT)\nprint(\"start_dates =\", start_dates)\nend_dates = collect_by_instrument(REV.ATTRIBUTE_ITEM_ENDDATE_CURRENT)\nprint(\"end_dates =\", end_dates)\nposting_date = REV.postingdate\nprint(\"posting_date =\", posting_date)\n## Schedule\np = period(start_dates, end_dates, \"M\")\nSchedule = schedule(p, {\n    \"period_date\": \"period_date\",\n    \"month_end\": \"end_of_month(period_date)\",\n    \"days\": \"if(eq(start_date, end_date), add(days_between(start_of_month(period_date), end_of_month(period_date)), 1), if(eq(period_index, 0), days_between(start_date, end_of_month(start_date)), if(eq(period_index, subtract(total_periods, 1)), add(days_between(start_of_month(end_date), end_date), 1), add(days_between(start_of_month(period_date), end_of_month(period_date)), 1))))\",\n    \"LTD_days\": \"if(eq(start_date, end_date), add(days_between(start_of_month(start_date), end_of_month(end_date)), 1), if(eq(period_date, end_date), days_between(start_date, end_date), days_between(start_date, end_of_month(period_date))))\",\n    \"daily_revenue\": \"if(eq(start_date, end_date), divide(allocation, days), divide(allocation, 365))\",\n    \"period_revenue\": \"multiply(multiply(daily_revenue, days), -1)\",\n    \"LTD_revenue\": \"multiply(if(lt(period_date, subtract_months(posting_date, 1)), multiply(daily_revenue, days), 0), -1)\"\n}, {\"allocation\": allocation, \"posting_date\": posting_date})\nprint(Schedule)\nrecognition_results_LTD = schedule_sum(Schedule, \"LTD_revenue\")\nrecognition_results = schedule_filter(Schedule, \"month_end\", posting_date, \"period_revenue\")\n\nEOD_REVENUE = collect_by_instrument(EOD.BALANCES_ENDINGBALANCE_REVENUE)\nprint(\"EOD_REVENUE =\", EOD_REVENUE)\n## Iteration\nrevenue_adj = apply_each(recognition_results_LTD, \"subtract(each,array_get(EOD_REVENUE,index,0))\", {\"recognition_results_LTD\": recognition_results_LTD, \"EOD_REVENUE\": EOD_REVENUE})\nprint(\"revenue_adj =\", revenue_adj)\n\nREV = add(recognition_results, revenue_adj)\nprint(\"REV =\", REV)\n\n## Create Transactions\ncreateTransaction(posting_date, posting_date, \"REVENUE\", REV, subinstrument_ids)\n\n## ═══════════════════════════════════════════════════════════════\n## STAGE 3 - UNBILLED CHARGE\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\n## Steps\ntotal_revenue = sum(recognition_results)\nprint(\"total_revenue =\", total_revenue)\nunbilled_charge = multiply(total_revenue, -1)\nprint(\"unbilled_charge =\", unbilled_charge)\nEOD_UNBILLED = EOD.BALANCES_ENDINGBALANCE_UNBILLED\nprint(\"EOD_UNBILLED =\", EOD_UNBILLED)\nEOD_BILLING = EOD.BALANCES_ENDINGBALANCE_BILLING\nprint(\"EOD_BILLING =\", EOD_BILLING)\n## Conditional Logic\nUnbilled_amount = if(gt(add(EOD_UNBILLED, unbilled_charge) , EOD_BILLING), unbilled_charge, multiply(EOD_UNBILLED, -1))\nprint(\"Unbilled_amount =\", Unbilled_amount)\n\n\n## Create Transactions\ncreateTransaction(posting_date, posting_date, \"UNBILLED_CHARGE\", Unbilled_amount, 0.0)",
    "created_at": "2026-04-22T21:05:05.817079+00:00",
    "updated_at": "2026-04-23T18:48:06.580590+00:00"
  }
