        "generatedCode": "## ═══════════════════════════════════════════════════════════════\n## STAGE 1 - PARAMETERS\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\nnetImpairment = subtract(PeriodImpairment,priotImpairment)\nImpairment_Gain = if(gt(PeriodImpairment,0),PeriodImpairment,0)\nImpairment_Loss = if(lt(netImpairment,0),netImpairment,0)\nInterest_Accrual = if(eq(OriginationDate,postingdate),0,interestAccrual)\nOrigination_Principal = if(eq(OriginationDate,postingdate),LoanAmount,0)\ninterestAccrual = schedule_first(Schedule, \"interestAccrued\")\nPeriodImpairment = schedule_sum(Schedule, \"impairmentCurrent\")\n\n## Steps\nMeasurementType = collect_all(MeasurementType.MeasurementType)\nprint(\"MeasurementType =\", MeasurementType)\nStartDate = collect_by_instrument(ECF.StartDate)\nprint(\"StartDate =\", StartDate)\nExpectedCF = collect_by_instrument(ECF.ExpectedCF)\nprint(\"ExpectedCF =\", ExpectedCF)\npostingdate = EOD.postingdate\nprint(\"postingdate =\", postingdate)\neffectivedate = EOD.effectivedate\nprint(\"effectivedate =\", effectivedate)\nsubinstrumentid = EOD.subinstrumentid\nprint(\"subinstrumentid =\", subinstrumentid)\nOriginationDate = EOD.ATTRIBUTE_ORIGINATIONDATE_CURRENT\nprint(\"OriginationDate =\", OriginationDate)\nLoanAmount = EOD.ATTRIBUTE_LOANAMOUNT_CURRENT\nprint(\"LoanAmount =\", LoanAmount)\nTerm = EOD.ATTRIBUTE_TERM_CURRENT\nprint(\"Term =\", Term)\nNoteRate = EOD.ATTRIBUTE_NOTERATE_CURRENT\nprint(\"NoteRate =\", NoteRate)\npriotImpairment = EOD.BALANCES_ENDINGBALANCE_IMPAIRMENT\nprint(\"priotImpairment =\", priotImpairment)\nMonthly_Rate = NoteRate/1200\nprint(\"Monthly_Rate =\", Monthly_Rate)\nPMT_AM = pmt(Monthly_Rate,Term,-LoanAmount)\nprint(\"PMT_AM =\", PMT_AM)\nFirst_Month = months_between(OriginationDate,postingdate)\nprint(\"First_Month =\", First_Month)\nmaturitydate = add_months(OriginationDate,Term)\nprint(\"maturitydate =\", maturitydate)\n## Conditional Logic\nUPB = if(eq(OriginationDate,postingdate), LoanAmount, EOD.BALANCES_ENDINGBALANCE_UPB)\nprint(\"UPB =\", UPB)\n",
