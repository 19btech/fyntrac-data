      {
        "name": "Stage 2 - Schedule",
        "priority": 2,
        "ruleType": "schedule",
        "generatedCode": "## ═══════════════════════════════════════════════════════════════\n## STAGE 2 - SCHEDULE\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\nMeasurementType = collect_all(MeasurementType.MeasurementType)\nStartDate = collect_by_instrument(ECF.StartDate)\nExpectedCF = collect_by_instrument(ECF.ExpectedCF)\npostingdate = EOD.postingdate\neffectivedate = EOD.effectivedate\nsubinstrumentid = EOD.subinstrumentid\nOriginationDate = EOD.ATTRIBUTE_ORIGINATIONDATE_CURRENT\nLoanAmount = EOD.ATTRIBUTE_LOANAMOUNT_CURRENT\nTerm = EOD.ATTRIBUTE_TERM_CURRENT\nNoteRate = EOD.ATTRIBUTE_NOTERATE_CURRENT\npriotImpairment = EOD.BALANCES_ENDINGBALANCE_IMPAIRMENT\nMonthly_Rate = NoteRate/1200\nPMT_AM = pmt(Monthly_Rate,Term,-LoanAmount)\nFirst_Month = months_between(OriginationDate,postingdate)\nmaturitydate = add_months(OriginationDate,Term)\nUPB = if(eq(OriginationDate,postingdate), LoanAmount, EOD.BALANCES_ENDINGBALANCE_UPB)\n\n## Steps\n## Schedule\np = period(postingdate, maturitydate, \"M\")\nSchedule = schedule(p, {\n    \"period_date\": \"period_date\",\n    \"month_end\": \"end_of_month(period_date)\",\n    \"monthNumber\": \"if(eq(period_index,0),First_Month,lag('monthNumber',1,First_Month)+1)\",\n    \"openingBalance\": \"if(eq(period_index,0),UPB,lag('closingBalance',1,0))\",\n    \"interestAccrued\": \"multiply(openingBalance,Monthly_Rate)\",\n    \"contractualCF\": \"if(eq(month_end,maturitydate),add(interestAccrued,lag('closingBalance',1,0)),PMT_AM)\",\n    \"ExpectedCFA\": \"if(eq(OriginationDate,postingdate),contractualCF,lookup(ExpectedCF, StartDate, month_end))\",\n    \"principalPayment\": \"contractualCF-interestAccrued\",\n    \"closingBalance\": \"subtract(openingBalance,principalPayment)\",\n    \"discountFactor\": \"1/pow(1+Monthly_Rate, monthNumber)\",\n    \"PV_CCF\": \"multiply(discountFactor,contractualCF)\",\n    \"PV_ECF\": \"multiply(discountFactor,ExpectedCFA)\",\n    \"impairmentCurrent\": \"subtract(PV_ECF,PV_CCF)\",\n    \"startdate\": \"StartDate\"\n}, {\"First_Month\": First_Month, \"UPB\": UPB, \"Monthly_Rate\": Monthly_Rate, \"maturitydate\": maturitydate, \"PMT_AM\": PMT_AM, \"ExpectedCF\": ExpectedCF, \"StartDate\": StartDate, \"pow\": pow, \"OriginationDate\": OriginationDate, \"postingdate\": postingdate})\nprint(Schedule)\ninterestAccrual = schedule_first(Schedule, \"interestAccrued\")\nPeriodImpairment = schedule_sum(Schedule, \"impairmentCurrent\")\n\nnetImpairment = subtract(PeriodImpairment,priotImpairment)\nprint(\"netImpairment =\", netImpairment)\nImpairment_Gain = if(gt(PeriodImpairment,0),PeriodImpairment,0)\nprint(\"Impairment_Gain =\", Impairment_Gain)\nImpairment_Loss = if(lt(netImpairment,0),netImpairment,0)\nprint(\"Impairment_Loss =\", Impairment_Loss)\nInterest_Accrual = if(eq(OriginationDate,postingdate),0,interestAccrual)\nprint(\"Interest_Accrual =\", Interest_Accrual)\nOrigination_Principal = if(eq(OriginationDate,postingdate),LoanAmount,0)\nprint(\"Origination_Principal =\", Origination_Principal)\n\n## Create Transactions\ncreateTransaction(postingdate, effectivedate, \"IMPAIRMENT_GAIN\", Impairment_Gain, subinstrumentid)\ncreateTransaction(postingdate, postingdate, \"IMPAIRMENT_LOSS\", Impairment_Loss, subinstrumentid)\ncreateTransaction(postingdate, postingdate, \"INTEREST_ACCRUAL\", Interest_Accrual, subinstrumentid)\ncreateTransaction(postingdate, postingdate, \"ORIGINATION_PRINCIPAL\", Origination_Principal, subinstrumentid)",
        "variables": [
