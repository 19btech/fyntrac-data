        "priority": 3,
        "ruleType": "simple_calc",
        "generatedCode": "## ═══════════════════════════════════════════════════════════════\n## STEP 3 - NORMAL ACCRUAL\n## ═══════════════════════════════════════════════════════════════\n\n## Dependencies from saved rules\nposting_date = EOD.postingdate\neffective_date = EOD.effectivedate\nsubinstrumentid = EOD.subinstrumentid\npayment_date = TRANX.effectivedate\nreplay_date = REPLAY.effectivedate\ntimeline_array = collect_by_instrument(REPLAY.effectivedate)\ntime = timeline_array\ntimeline_list = array_append(time,posting_date)\nreplay_upb = coalesce(REPLAY.BALANCES_BEGINNINGBALANCE_UNPAID_PRINCIPAL_BALANCE,0)\nreplay_air = REPLAY.BALANCES_BEGINNINGBALANCE_ACCRUED_INTEREST_RECEIVABLE\nreplay_remit = collect_by_instrument(REPLAY.TRANSACTIONS_AMOUNT_REMIT)\ninterest_rate = EOD.ATTRIBUTE_INTEREST_RATE_CURRENT/100\npayment_amount = if(eq(payment_date,posting_date), TRANX.TRANSACTIONS_AMOUNT_REMIT, 0)\nTimeline_list_count = count(timeline_list)\nReplay_EndingUPB = schedule_last(Schedule, \"End_UPB\")\nReplay_EndingAIR = schedule_last(Schedule, \"End_AIR\")\n\n## Steps\nBeginningUPB = EOD.BALANCES_BEGINNINGBALANCE_UNPAID_PRINCIPAL_BALANCE\nprint(\"BeginningUPB =\", BeginningUPB)\nBeginningAIR = EOD.BALANCES_BEGINNINGBALANCE_ACCRUED_INTEREST_RECEIVABLE\nprint(\"BeginningAIR =\", BeginningAIR)\nPayment_interest = min(payment_amount, BeginningAIR)*-1\nprint(\"Payment_interest =\", Payment_interest)\npayment_principal = max(payment_amount+Payment_interest, 0)*-1\nprint(\"payment_principal =\", payment_principal)\nInterestAccrual = ((BeginningUPB+payment_principal)*interest_rate)/360\nprint(\"InterestAccrual =\", InterestAccrual)\nEndingUPB = BeginningUPB+payment_principal\nprint(\"EndingUPB =\", EndingUPB)\nEndingAIR = BeginningAIR+Payment_interest+InterestAccrual\nprint(\"EndingAIR =\", EndingAIR)\nPrincipal_Adj = if(eq(Replay_EndingUPB,0),0,subtract(Replay_EndingUPB,EndingUPB))\nprint(\"Principal_Adj =\", Principal_Adj)\nInterest_Adj = if(eq(Replay_EndingAIR,0),0,subtract(Replay_EndingAIR,EndingAIR))\nprint(\"Interest_Adj =\", Interest_Adj)\n\n## Create Transactions\ncreateTransaction(posting_date, posting_date, \"Principal_Adjustment\", Principal_Adj, subinstrumentid)\ncreateTransaction(posting_date, posting_date, \"Interest_Adjustment\", Interest_Adj, subinstrumentid)\ncreateTransaction(posting_date, payment_date, \"Payment_Interest\", Payment_interest, subinstrumentid)\ncreateTransaction(posting_date, payment_date, \"Payment_UPB\", payment_principal, subinstrumentid)\ncreateTransaction(posting_date, posting_date, \"Servicing_Interest_Accrual\", InterestAccrual, subinstrumentid)",
