                {
                  "name": "Beg_AIR",
                  "formula": "if(eq(period_index, 0),replay_air,lag('End_AIR',1,0)+(lag('Accrual',1,0)*days))"
                },
                {
                  "name": "Remit_am",
                  "formula": "coalesce(replay_remit,0)"
                },
                {
                  "name": "Int_Paid",
                  "formula": "min(Remit_am,Beg_AIR)"
                },
                {
                  "name": "Prin_Paid",
                  "formula": "max(Remit_am-Int_Paid,0)"
                },
                {
                  "name": "End_UPB",
                  "formula": "subtract(Beg_UPB,Prin_Paid)"
                },
                {
                  "name": "Accrual",
                  "formula": "(interest_rate*End_UPB)/360"
                },
                {
                  "name": "End_AIR",
                  "formula": "Beg_AIR-Int_Paid+Accrual"
                }
              ],
              "outputs": [
                {
                  "id": "o_1777090979337_oz456",
