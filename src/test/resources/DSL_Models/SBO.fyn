    "combinedCode": "## ═══════════════════════════════════════════════════════════════\n## SBO_RULES\n## ═══════════════════════════════════════════════════════════════\n\n## Steps\nINT_ACC_postingdate = INT_ACC.postingdate\nprint(\"INT_ACC_postingdate =\", INT_ACC_postingdate)\nINT_ACC_effectivedate = INT_ACC.effectivedate\nprint(\"INT_ACC_effectivedate =\", INT_ACC_effectivedate)\nint_rate_current = INT_ACC.ATTRIBUTE_INTEREST_RATE_CURRENT\nprint(\"int_rate_current =\", int_rate_current)\nunpaid_principal_balance = INT_ACC.BALANCES_ENDINGBALANCE_UNPAID_PRINCIPAL_BALANCE\nprint(\"unpaid_principal_balance =\", unpaid_principal_balance)\naccrued_interest_receivable = INT_ACC.BALANCES_ENDINGBALANCE_ACCRUED_INTEREST_RECEIVABLE\nprint(\"accrued_interest_receivable =\", accrued_interest_receivable)\nservicing_interest_accrual = INT_ACC.BALANCES_ENDINGBALANCE_SERVICING_INTEREST_ACCRUAL\nprint(\"servicing_interest_accrual =\", servicing_interest_accrual)\nPMT_postingdate = PMT.postingdate\nprint(\"PMT_postingdate =\", PMT_postingdate)\nPMT_effectivedate = PMT.effectivedate\nprint(\"PMT_effectivedate =\", PMT_effectivedate)\npmt_remit = PMT.TRANSACTIONS_AMOUNT_REMIT\nprint(\"pmt_remit =\", pmt_remit)\nORG_postingdate = ORIG.postingdate\nprint(\"ORG_postingdate =\", ORG_postingdate)\nORG_effectivedate = ORIG.effectivedate\nprint(\"ORG_effectivedate =\", ORG_effectivedate)\nPurchase_upb = ORIG.ATTRIBUTE_LOAN_AMOUNT_CURRENT\nprint(\"Purchase_upb =\", Purchase_upb)\nPurchase_air = ORIG.ATTRIBUTE_INTEREST_RECEIVABLE_CONSUMER_CURRENT\nprint(\"Purchase_air =\", Purchase_air)\nSub = INT_ACC.subinstrumentid\nprint(\"Sub =\", Sub)\nPayment_interest = min(pmt_remit, accrued_interest_receivable)*-1\nprint(\"Payment_interest =\", Payment_interest)\npayment_principal = max(pmt_remit+Payment_interest, 0)*-1\nprint(\"payment_principal =\", payment_principal)\nInterestAccrual = ((unpaid_principal_balance+payment_principal)*int_rate_current)/36000\nprint(\"InterestAccrual =\", InterestAccrual)\n\n## Create Transactions\ncreateTransaction(ORIG.postingdate, ORIG.effectivedate, \"PURCHASE_UPB\", Purchase_upb, 1.0)\ncreateTransaction(ORIG.postingdate, ORIG.effectivedate, \"PURCHASE_INTEREST\", Purchase_air, 1.0)\ncreateTransaction(PMT.postingdate, PMT.effectivedate, \"PAYMENT_INTEREST\", Payment_interest, 1.0)\ncreateTransaction(PMT.postingdate, PMT.effectivedate, \"PAYMENT_UPB\", payment_principal, 1.0)\ncreateTransaction(INT_ACC.postingdate, INT_ACC.effectivedate, \"SERVICING_INTEREST_ACCRUAL\", InterestAccrual, 1.0)",
