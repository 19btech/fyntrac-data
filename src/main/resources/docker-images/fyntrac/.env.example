# ──────────────────────────────────────────────────────────────────────────────
# fyntrac-docker-compose.yml — environment variable reference
# Source this from ~/.dev_profile on both local machine and VM.
#
# Usage:
#   source ~/.dev_profile
#   docker compose -f fyntrac-docker-compose.yml up -d <service>
#
# Or use the helper:
#   ./run-fyntrac-docker-images.sh <version> all
# ──────────────────────────────────────────────────────────────────────────────

# ── Image version ─────────────────────────────────────────────────────────────
FYNTRAC_VERSION=0.0.3-SNAPSHOT

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=test          # test | prod

# ── Host / VM ─────────────────────────────────────────────────────────────────
BASE_URI=localhost                   # set to VM IP on remote, e.g. 192.168.1.10

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_NAME=master
MONGODB_USERNAME=root
MONGODB_PSWD=R3s3rv%23313           # URL-encoded for connection strings (%23 = #)
MONGODB_AUTH_DATABASE=admin

# ── Zitadel OAuth2 ────────────────────────────────────────────────────────────
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=
ZITADEL_ISSUER_URI=
ZITADEL_PROJECT_ID=

# ── AI / External APIs ────────────────────────────────────────────────────────
GOOGLE_API_KEY=                      # for dsl service
ANTHROPIC_API_KEY=                   # for insight service

# ── Port overrides (optional, defaults match service ports) ───────────────────
# DATALOADER_PORT=8081
# MODEL_PORT=8082
# GL_PORT=8083
# REPORTING_PORT=8084
# GATEWAY_PORT=8585
# DSL_PORT=8000
# DSL_MODEL_PORT=8090
# DSL_UI_PORT=3000
# WEB_PORT=3030
# INSIGHT_PORT=4000
# INSIGHT_UI_PORT=3001

# ── Optional overrides ────────────────────────────────────────────────────────
# NEXT_PUBLIC_TENANT=Test
# NODE_ENV=production
# LOG_LEVEL=INFO
# MEMCACHED_HOST=memcached
# MEMCACHED_PORT=11211
# CORS_ALLOWED_ORIGINS=http://localhost:3030
# PULSAR_SERVICE_URL=pulsar://pulsar:6650
# DSL_STUDIO_URI=http://localhost:3000
